{
  "name": "lectern",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node -e \"require('fs').mkdirSync('dist', {recursive:true})\"",
    "dev": "concurrently -n vite,worker -c cyan,yellow \"vite\" \"wrangler dev --port 8787\"",
    "dev:seed": "wrangler d1 execute lectern-db --local --file=worker/schema.sql && wrangler d1 execute lectern-db --local --file=worker/seed.sql",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250718.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
